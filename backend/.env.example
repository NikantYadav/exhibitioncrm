PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://ezammzqvbjgpuzleqmla.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Backwards-compatible alias (optional)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# AI Services (at least one required)
# Google Gemini - Recommended, supports chat, transcription, and analysis
GOOGLE_AI_API_KEY=your_google_ai_api_key
# OR use GEMINI_API_KEY
GEMINI_API_KEY=your_gemini_api_key
# OpenAI - Optional fallback
OPENAI_API_KEY=your_openai_api_key

# Optional
# Exa web search. Add multiple keys for automatic rotation on rate limits:
# either comma-separate them here, or use EXA_API_KEY_1, EXA_API_KEY_2, ...
EXA_API_KEY=your_exa_api_key

# Optional — Sentry structured logs for cost-instrumentation metrics
# (card image size, Gemini tokens, Exa cost — see INFRASTRUCTURE_ANALYSIS.md).
# When unset, Sentry init is skipped entirely (no-op, same as the Flutter app's
# SENTRY_DSN pattern).
SENTRY_DSN=
SENTRY_ENV=development

# Optional — Resend (transactional email). Powers the in-app "Contact Support"
# form (POST /api/support/contact). Sends from support@exono.ai (verified
# domain) to contact@exono.ai. When unset, the endpoint returns 503.
RESEND_API_KEY=your_resend_api_key
