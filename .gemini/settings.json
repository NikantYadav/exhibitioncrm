{
  "mcpServers": {
    "code-review-graph": {
      "command": "/home/nikant/.pyenv/versions/3.10.11/bin/python3.10",
      "args": [
        "-m",
        "code_review_graph",
        "serve"
      ],
      "cwd": "/home/nikant/Desktop/crm"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .gemini/hooks/crg-session-start.sh",
            "name": "code-review-graph status",
            "timeout": 10000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "type": "command",
            "command": "bash .gemini/hooks/crg-update.sh",
            "name": "code-review-graph update",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
